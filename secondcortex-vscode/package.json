{
  "name": "secondcortex",
  "displayName": "SecondCortex",
  "description": "Your AI-Powered Second Brain for Development Context — tracks IDE activity, enforces a Semantic Firewall, and enables Workspace Resurrection.",
  "version": "0.1.9",
  "publisher": "secondcortex-labs",
  "repository": {
    "type": "git",
    "url": "https://github.com/Syed-Suhaan/SecondCortex-Labs"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "icon": "media/icon.png",
  "categories": [
    "Machine Learning",
    "Education",
    "Other"
  ],
  "keywords": [
    "AI",
    "productivity",
    "context",
    "resurrection",
    "security"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "secondcortex-sidebar",
          "title": "SecondCortex",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "secondcortex-sidebar": [
        {
          "type": "webview",
          "id": "secondcortex.chatView",
          "name": "SecondCortex Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "secondcortex.resurrectWorkspace",
        "title": "SecondCortex: Resurrect Workspace"
      },
      {
        "command": "secondcortex.askQuestion",
        "title": "SecondCortex: Ask a Question"
      },
      {
        "command": "secondcortex.toggleCapture",
        "title": "SecondCortex: Toggle Context Capture"
      },
      {
        "command": "secondcortex.login",
        "title": "SecondCortex: Log In"
      },
      {
        "command": "secondcortex.logout",
        "title": "SecondCortex: Log Out"
      },
      {
        "command": "secondcortex.openShadowGraph",
        "title": "SecondCortex: Open Shadow Graph"
      }
    ],
    "configuration": {
      "title": "SecondCortex",
      "properties": {
        "secondcortex.backendUrl": {
          "type": "string",
          "default": "https://sc-backend-suhaan.azurewebsites.net",
          "description": "The URL of the SecondCortex Azure backend API."
        },
        "secondcortex.frontendUrl": {
          "type": "string",
          "default": "https://sc-frontend-suhaan.azurewebsites.net",
          "description": "The URL of the SecondCortex frontend dashboard used in the Shadow Graph panel."
        },
        "secondcortex.debouncerDelayMs": {
          "type": "number",
          "default": 30000,
          "description": "Milliseconds of active editing before a context snapshot is captured."
        },
        "secondcortex.noiseThresholdMs": {
          "type": "number",
          "default": 10000,
          "description": "Milliseconds — if a file is closed before this threshold, it is ignored as noise."
        },
        "secondcortex.captureEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable automatic context capture."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "vsix": "npx @vscode/vsce package --allow-star-activation",
    "publish:patch": "npx @vscode/vsce publish patch --allow-star-activation",
    "publish:minor": "npx @vscode/vsce publish minor --allow-star-activation",
    "publish:major": "npx @vscode/vsce publish major --allow-star-activation"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vscode/test-electron": "^2.3.8",
    "eslint": "^8.56.0"
  },
  "dependencies": {
    "minimatch": "^9.0.0",
    "node-fetch": "^3.3.0",
    "typescript": "^5.3.0"
  }
}

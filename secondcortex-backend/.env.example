# SecondCortex Backend - Environment Configuration
# Copy this file to .env and replace placeholders.

# ------------------------------
# LLM routing (task-aware)
# ------------------------------
# Global default provider for all tasks:
#   openai | github_models | groq
LLM_PROVIDER_DEFAULT=openai

# Optional per-task overrides:
# LLM_PROVIDER_RETRIEVER=groq
# LLM_PROVIDER_PLANNER=groq
# LLM_PROVIDER_EXECUTOR=openai
# LLM_PROVIDER_SIMULATOR=openai
# LLM_PROVIDER_ARCHAEOLOGY=openai
# LLM_PROVIDER_EMBEDDINGS=openai

# Optional per-task emergency fallback providers:
# LLM_FALLBACK_PROVIDER_RETRIEVER=github_models
# LLM_FALLBACK_PROVIDER_PLANNER=github_models
# LLM_FALLBACK_PROVIDER_EXECUTOR=github_models
# LLM_FALLBACK_PROVIDER_SIMULATOR=groq
# LLM_FALLBACK_PROVIDER_ARCHAEOLOGY=groq
# LLM_FALLBACK_PROVIDER_EMBEDDINGS=github_models

# ------------------------------
# OpenAI API (primary inference)
# ------------------------------
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ------------------------------
# GitHub Models / Groq (optional alternates)
# ------------------------------
GITHUB_TOKEN=ghp_YOUR_GITHUB_TOKEN_HERE
GITHUB_MODELS_ENDPOINT=https://models.inference.ai.azure.com
GITHUB_MODELS_CHAT_MODEL=gpt-4o
GITHUB_MODELS_EMBEDDING_MODEL=text-embedding-3-small

GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE
GROQ_MODEL=llama-3.1-8b-instant
GROQ_ENDPOINT=https://api.groq.com/openai/v1

# ------------------------------
# Rate limiting (provider-aware)
# ------------------------------
LLM_RATE_LIMIT_DEFAULT_PER_MINUTE=60
LLM_RATE_LIMIT_OPENAI_PER_MINUTE=120
LLM_RATE_LIMIT_GITHUB_MODELS_PER_MINUTE=60
LLM_RATE_LIMIT_GROQ_PER_MINUTE=12
LLM_RATE_LIMIT_MAX_RETRIES=2

# ------------------------------
# Storage / Auth / Server
# ------------------------------
# Local Chroma path (recommended on Azure/App Service: /home/chroma_db)
CHROMA_DB_PATH=./chroma_db

JWT_SECRET=your-jwt-secret-here
HOST=0.0.0.0
PORT=8000

# Optional compatibility aliases
# LLM_PROVIDER=github_models

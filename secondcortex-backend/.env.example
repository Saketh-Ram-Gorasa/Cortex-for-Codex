# SecondCortex Backend — Environment Configuration
# Copy this file to .env and fill in your credentials.

# ── LLM Provider ─────────────────────────────────────────────
# Options: "github_models" (default, free) or "azure_openai"
LLM_PROVIDER=github_models

# ── GitHub Models (recommended — free via GitHub Marketplace) ─
# Generate a PAT at: https://github.com/settings/tokens
# Enable "GitHub Models" scope in Settings > Developer settings
GITHUB_TOKEN=ghp_YOUR_GITHUB_TOKEN_HERE
GITHUB_MODELS_ENDPOINT=https://models.inference.ai.azure.com
GITHUB_MODELS_CHAT_MODEL=gpt-4o
GITHUB_MODELS_EMBEDDING_MODEL=text-embedding-3-small

# ── Azure OpenAI (legacy — requires Azure OpenAI access) ─────
# Only needed if LLM_PROVIDER=azure_openai
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/
AZURE_OPENAI_API_KEY=YOUR_API_KEY_HERE
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002

# ── Azure AI Search (Vector DB) ─────────────────────────────
AZURE_SEARCH_ENDPOINT=https://sc-search-suhaan.search.windows.net
AZURE_SEARCH_API_KEY=YOUR_SEARCH_KEY_HERE
AZURE_SEARCH_INDEX_NAME=secondcortex-snapshots

# ── Server ───────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
